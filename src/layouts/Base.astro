---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  /** Path of the current page used to highlight the active nav link. e.g. '/menu' */
  current?: string;
}

const {
  title,
  description,
  current = '',
} = Astro.props;

const isActive = (path: string) => current === path ? 'is-active' : '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/public/image%2010.png" />

  <script type="module" is:inline>
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.13.0/firebase-app.js";
    import { getAnalytics } from "https://www.gstatic.com/firebasejs/10.13.0/firebase-analytics.js";
    const firebaseConfig = {
      apiKey: "AIzaSyDg2azEJq3kvEYB5VezljXvGygmGQOtVOs",
      authDomain: "kala-6d802.firebaseapp.com",
      projectId: "kala-6d802",
      storageBucket: "kala-6d802.firebasestorage.app",
      messagingSenderId: "341282211513",
      appId: "1:341282211513:web:a7439d74b0bbe32c647d68",
      measurementId: "G-3JLE857RPM"
    };
    const app = initializeApp(firebaseConfig);
    getAnalytics(app);
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />

  {/* Smooth cross-document View Transitions — turns MPA navigation
      into SPA-feeling page-to-page fades + persistent navbar/footer. */}
  <ClientRouter />
</head>

<body>

  <!-- Announce -->
  <div class="announce" transition:persist>
    <span class="announce-dot"></span>
    <span>Now serving lunch · Tuesday – Saturday · 11a – 3p</span>
  </div>

  <!-- Navigation -->
  <header class="nav" id="nav" transition:persist transition:name="site-nav">
    <div class="nav-inner container">
      <a href="/" class="brand" aria-label="KALA — Greek and More">
        <img class="brand-mark" src="/public/image%2010.png" alt="" />
        <span class="brand-word">KALA</span>
      </a>

      <nav class="nav-links" aria-label="Primary">
        <a href="/menu" class={isActive('/menu')}>Menu</a>
        <a href="/our-story" class={isActive('/our-story')}>Our Story</a>
        <a href="/contact" class={isActive('/contact')}>Contact</a>
      </nav>

      <div class="nav-actions">
        <a href="/reservations" class="link-quiet">Reservations</a>
        <a href="/order" class="btn btn-primary btn-sm">Order Online</a>
      </div>

      <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <div class="mobile-menu" id="mobileMenu" aria-hidden="true" transition:persist>
    <a href="/menu">Menu</a>
    <a href="/our-story">Our Story</a>
    <a href="/contact">Contact</a>
    <a href="/reservations">Reservations</a>
    <a href="/order" class="btn btn-primary">Order Online</a>
  </div>

  <main id="top">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer" id="contact" transition:persist transition:name="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="brand brand-light">
            <img class="brand-mark" src="/public/image%2010.png" alt="" />
            <span class="brand-word">KALA</span>
          </a>
          <p class="footer-tagline">Greek and More</p>
          <p class="footer-blurb">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec euismod
            tempor lectus, sed pretium nisi tincidunt eu.
          </p>
          <div class="socials">
            <a href="#" data-social-link="Instagram" aria-label="Instagram">
              <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
            </a>
            <a href="#" data-social-link="Facebook" aria-label="Facebook">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 8h3V4h-3a4 4 0 0 0-4 4v2H7v4h3v8h4v-8h3l1-4h-4V8Z" fill="currentColor"/></svg>
            </a>
            <a href="#" data-social-link="TikTok" aria-label="TikTok">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 3v3.5a3.5 3.5 0 0 0 3.5 3.5h.5v3.5a7 7 0 0 1-4-1.3V17a5.5 5.5 0 1 1-5.5-5.5h.5v3.5h-.5a2 2 0 1 0 2 2V3h3.5Z" fill="currentColor"/></svg>
            </a>
            <a href="#" data-social-link="X" aria-label="X (Twitter)">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.5 3H21l-7.4 8.5L22 21h-6.8l-5.3-6.6L3.9 21H.4l7.9-9L0 3h6.9l4.8 6.1L17.5 3Zm-1.2 16h1.9L7.8 5h-2l10.5 14Z" fill="currentColor"/></svg>
            </a>
          </div>
        </div>

        <div class="footer-col">
          <h4>Visit</h4>
          <ul>
            <li>1500 Queen Anne Ave N</li>
            <li>Seattle, WA 98109</li>
            <li><a href="/contact">Get Directions</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Explore</h4>
          <ul>
            <li><a href="/menu">Menu</a></li>
            <li><a href="/our-story">Our Story</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/reservations">Reservations</a></li>
            <li><a href="/order">Order Online</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Hours</h4>
          <ul>
            <li>Tue – Thu · 11a – 9p</li>
            <li>Fri – Sat · 11a – 10p</li>
            <li>Sun · 12p – 8p</li>
            <li class="dim">Mon · Closed</li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Contact</h4>
          <ul>
            <li><a href="tel:5551234567">(555) 123 — 4567</a></li>
            <li><a href="mailto:niko@kalaeats.com">niko@kalaeats.com</a></li>
            <li><a href="#">Private events</a></li>
            <li><a href="#">Press inquiries</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <p>© 2026 KALA Greek and More. All rights reserved.</p>
        <p class="footer-meta">
          <span class="kvline"></span>
          Crafted with care · Seattle
        </p>
      </div>
    </div>
  </footer>

  <!-- Sticky Order Button -->
  <a href="/order" class="sticky-order" id="stickyOrder" aria-label="Order online" transition:persist>
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 7h14l-1.5 11a2 2 0 0 1-2 1.7H8.5a2 2 0 0 1-2-1.7L5 7Zm3-3a4 4 0 0 1 8 0v3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <span>Order Online</span>
  </a>

  <!-- Coming-soon modal (shared, fires on any [data-social-link] click) -->
  <div class="social-modal" data-social-modal hidden role="dialog" aria-modal="true" aria-labelledby="social-modal-title" transition:persist>
    <div class="social-modal-backdrop" data-social-modal-close></div>
    <div class="social-modal-card" role="document">
      <button type="button" class="social-modal-close" data-social-modal-close aria-label="Close">×</button>
      <div class="social-modal-meander" aria-hidden="true"></div>
      <span class="eyebrow social-modal-eyebrow">
        <span data-social-platform>Instagram</span>
      </span>
      <h2 class="social-modal-title" id="social-modal-title">Coming soon</h2>
      <p class="social-modal-sub">
        We're getting our <span data-social-platform>Instagram</span> set up.
        Until then, see you in person at 1500 Queen Anne Ave N.
      </p>
      <button type="button" class="btn btn-primary social-modal-btn" data-social-modal-close>
        Got it
      </button>
    </div>
  </div>

  <script src="/menu-data.js" is:inline data-astro-rerun></script>
  <script src="/pos.js" is:inline data-astro-rerun></script>
  <script src="/script.js" is:inline data-astro-rerun></script>
</body>
</html>
