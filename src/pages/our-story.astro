---
import Base from '../layouts/Base.astro';
---
<Base
  title="Our Story — KALA Greek and More"
  description="The story of KALA — a family-run Greek restaurant rooted in Mediterranean tradition and the coastal kitchen."
  current="/our-story"
>

  <!-- Page header -->
  <section class="page-header has-bg is-story">
    <div class="container">
      <span class="eyebrow">Our Story</span>
      <h1>KALA</h1>
      <span class="page-sub">rooted in tradition</span>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus quis
        pellentesque magna. Praesent ut sollicitudin ligula, vitae laoreet justo.
      </p>
    </div>
  </section>

  <!-- Greek Key Divider -->
  <div class="meander-divider" aria-hidden="true"></div>

  <!-- Block 1 -->
  <section>
    <div class="container">
      <div class="story-block">
        <div class="story-block-text">
          <span class="eyebrow">Our Family</span>
          <h2>From a family table to <em>yours</em></h2>
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus quis
            pellentesque magna. Praesent ut sollicitudin ligula, vitae laoreet justo.
          </p>
          <p>
            Curabitur dapibus laoreet eros, vitae faucibus ipsum tincidunt vitae. Nam
            ultrices, magna a porttitor laoreet, sapien lorem feugiat lectus.
          </p>
        </div>
        <div class="story-block-image">
          <img
            src="/public/our%20story/family_table_v2.png"
            alt="Three generations of hands — elder, parent, and child — tearing a rustic Greek country loaf together over a blue-striped linen-covered table, with Kalamata olives in a painted blue-and-white ceramic bowl."
            loading="lazy" />
          <span class="caption">Family</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull quote -->
  <section class="pull-quote-wrap">
    <div class="pull-quote">
      <span class="open-q" aria-hidden="true">"</span>
      <blockquote>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit —
        phasellus quis pellentesque magna.
      </blockquote>
      <cite>The KALA family</cite>
    </div>
  </section>

  <!-- Block 2 — reversed -->
  <section>
    <div class="container">
      <div class="story-block reverse">
        <div class="story-block-text">
          <span class="eyebrow">The Coast</span>
          <h2>Mediterranean, <em>by way of the coast</em></h2>
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec euismod
            tempor lectus, sed pretium nisi tincidunt eu. Vivamus sit amet libero in
            lacus efficitur tincidunt.
          </p>
          <p>
            Nam ultrices, magna a porttitor laoreet, sapien lorem feugiat lectus, eget
            tincidunt lacus eros vitae nibh.
          </p>
          <a href="menu.html" class="link-arrow">Browse the menu <span>→</span></a>
        </div>
        <div class="story-block-image">
          <img
            src="/public/our%20story/coast_village_v2.png"
            alt="A whitewashed Greek fishing village with cobalt-blue domes above a small harbor, a weathered blue fishing boat moored below, pink bougainvillea spilling over a sun-warmed wall, and a painted blue-and-white ceramic bowl of Kalamata olives with olive branches in the foreground."
            loading="lazy" />
          <span class="caption">By the coast</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Block 3 — engraving showcase -->
  <section style="background: var(--off-white);">
    <div class="container">
      <div class="story-block">
        <div class="story-block-text">
          <span class="eyebrow">The Kitchen</span>
          <h2>Made by hand, <em>shared by the table</em></h2>
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent ut sollicitudin
            ligula, vitae laoreet justo. Curabitur dapibus laoreet eros, vitae faucibus ipsum
            tincidunt vitae.
          </p>
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam ultrices, magna a
            porttitor laoreet, sapien lorem feugiat lectus.
          </p>
        </div>
        <div class="story-block-image">
          <img
            src="/public/our%20story/kitchen_hands_v2.png"
            alt="Weathered hands wearing a gold wedding band scattering fresh oregano and thyme onto a white block of Greek feta drizzled with golden olive oil, on a rustic wooden board with a blue-and-white ceramic bowl of Kalamata olives, a lemon half, and a soft Greek-blue linen tea towel."
            loading="lazy" />
          <span class="caption">At the table</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="values">
    <div class="container">
      <header class="section-header" style="text-align: center; max-width: 640px; margin-left: auto; margin-right: auto;">
        <span class="eyebrow">What we stand for</span>
        <h2 class="section-title">Three things we promise</h2>
        <p class="section-sub" style="margin: 0 auto;">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec euismod tempor
          lectus, sed pretium nisi tincidunt eu.
        </p>
      </header>

      <div class="values-grid">
        <article class="value-card">
          <div class="value-image">
            <img src="/public/our%20story/value_hospitality.png" alt="A painted blue-and-white ceramic plate of warm pita and country bread with a halved fig and Kalamata olive, a matching small dish of olive oil with fresh herbs, and two terracotta cups of strong Greek coffee on a blue-and-white striped linen." loading="lazy" />
          </div>
          <h3>Hospitality</h3>
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus quis pellentesque magna.</p>
        </article>
        <article class="value-card">
          <div class="value-image">
            <img src="/public/our%20story/value_tradition.png" alt="Weathered hands wearing a gold wedding band kneading dough on a flour-dusted wooden table with a wooden rolling pin, a painted blue-and-white ceramic dish of olive oil with oregano, and a copper-bowled mortar and pestle with crushed herbs." loading="lazy" />
          </div>
          <h3>Tradition</h3>
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent ut sollicitudin ligula.</p>
        </article>
        <article class="value-card">
          <div class="value-image">
            <img src="/public/our%20story/value_sea.png" alt="A whitewashed stone dock at golden hour with Greek-blue rope coiled around a stone bollard, a sprig of olive branch on the stone, and a tiny painted blue-and-white ceramic dish of sea salt, looking out across the calm turquoise Aegean to two distant sailboats." loading="lazy" />
          </div>
          <h3>The Sea</h3>
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec euismod tempor lectus.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Invite CTA -->
  <section class="invite">
    <div class="container invite-inner">
      <span class="eyebrow">Come find us</span>
      <h2>Pull up <em>a chair</em></h2>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus sit amet libero in
        lacus efficitur tincidunt.
      </p>
      <div class="invite-actions">
        <a href="reservations.html" class="btn btn-primary btn-lg">
          Make a Reservation
          <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11M11 5l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="contact.html" class="btn btn-outline btn-lg">Get Directions</a>
      </div>
    </div>
  </section>

</Base>
