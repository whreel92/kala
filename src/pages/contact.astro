---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact — KALA Greek and More"
  description="Visit, call, or write to KALA — Greek and More. Address, phone, email, hours, and directions."
  current="/contact"
>

  <!-- Page header -->
  <section class="page-header has-bg is-contact">
    <div class="container">
      <h1>CONTACT</h1>
      <span class="page-sub">Find us by the harbor</span>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed pretium nisi
        tincidunt eu. Donec euismod tempor lectus.
      </p>
    </div>
  </section>

  <!-- Greek Key Divider -->
  <div class="meander-divider" aria-hidden="true"></div>

  <!-- Contact details -->
  <section class="visit">
    <div class="container visit-grid">
      <div class="visit-info">
        <span class="eyebrow">The details</span>
        <h2 class="section-title">Stop by, call, <em>or write</em></h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec euismod
          tempor lectus, sed pretium nisi tincidunt eu.
        </p>

        <dl class="info-list">
          <div class="info-row">
            <dt>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 2c-3.3 0-6 2.6-6 6 0 4.4 6 10 6 10s6-5.6 6-10c0-3.4-2.7-6-6-6Zm0 8.2A2.2 2.2 0 1 1 10 5.8a2.2 2.2 0 0 1 0 4.4Z" fill="currentColor"/></svg>
              Address
            </dt>
            <dd>
              1500 Queen Anne Ave N<br/>
              Seattle, WA 98109
            </dd>
          </div>
          <div class="info-row">
            <dt>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 3h3l2 5-2 1a10 10 0 0 0 5 5l1-2 5 2v3a2 2 0 0 1-2 2A14 14 0 0 1 3 5a2 2 0 0 1 2-2Z" fill="currentColor"/></svg>
              Phone
            </dt>
            <dd><a href="tel:5551234567">(555) 123 — 4567</a></dd>
          </div>
          <div class="info-row">
            <dt>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5Zm2 .5v.4l5 3.4 5-3.4v-.4H5Zm10 2.1-5 3.4-5-3.4V14.5h10V7.6Z" fill="currentColor"/></svg>
              Email
            </dt>
            <dd><a href="mailto:niko@kalaeats.com">niko@kalaeats.com</a></dd>
          </div>
          <div class="info-row">
            <dt>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 2a8 8 0 1 0 0 16 8 8 0 0 0 0-16Zm.8 4h-1.6v5l4 2.4.8-1.4-3.2-2Z" fill="currentColor"/></svg>
              Hours
            </dt>
            <dd>
              <span><b>Tue – Thu</b> · 11a – 9p</span>
              <span><b>Fri – Sat</b> · 11a – 10p</span>
              <span><b>Sun</b> · 12p – 8p</span>
              <span class="dim"><b>Mon</b> · Closed</span>
            </dd>
          </div>
        </dl>

        <div class="visit-buttons">
          <a
            href="https://www.google.com/maps/dir/?api=1&destination=1500+Queen+Anne+Ave+N+Seattle+WA+98109"
            class="btn btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >Get Directions</a>
          <a href="tel:5551234567" class="btn btn-outline">Call (555) 123-4567</a>
        </div>
      </div>

      <div class="visit-map" aria-label="Map of KALA at 1500 Queen Anne Ave N, Seattle">
        <div class="map-toolbar" role="group" aria-label="Map type">
          <button type="button" class="map-type-btn is-active" data-map-type="default">
            Default
          </button>
          <button type="button" class="map-type-btn" data-map-type="satellite">
            Satellite
          </button>
        </div>
        <div id="kala-map" class="map-canvas" data-kala-map></div>
      </div>

      <!-- Leaflet — loaded only on the Contact page -->
      <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin=""
      />
      <script
        is:inline
        src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""
        data-astro-rerun
      ></script>
      <script is:inline data-astro-rerun>
        (() => {
          const mount = document.querySelector('[data-kala-map]');
          if (!mount) return;
          if (mount.dataset.kalaMapInit === 'true') return;

          // Leaflet may not have finished executing yet when this inline
          // script runs (especially after a view transition where both the
          // CDN script tag and this one are re-inserted at the same time).
          // Poll briefly until `L` shows up, then init.
          const waitForLeaflet = (attempt) => {
            if (typeof L !== 'undefined') return initMap();
            if (attempt > 60) {
              console.warn('[KALA map] Leaflet failed to load — giving up.');
              return;
            }
            setTimeout(() => waitForLeaflet(attempt + 1), 100);
          };

          const initMap = () => {
            // Re-check the init guard in case multiple invocations queued
            if (mount.dataset.kalaMapInit === 'true') return;
            mount.dataset.kalaMapInit = 'true';

            // 1500 Queen Anne Ave N, Seattle, WA 98109
            const KALA_LATLNG = [47.63613, -122.35713];

            const map = L.map(mount, {
              zoomControl: true,
              scrollWheelZoom: false,
              attributionControl: true,
            }).setView(KALA_LATLNG, 16);

            const layers = {
              default: L.tileLayer(
                'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
                {
                  maxZoom: 19,
                  attribution:
                    '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                }
              ),
              satellite: L.tileLayer(
                'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
                {
                  maxZoom: 19,
                  attribution:
                    'Tiles &copy; Esri &mdash; Source: Esri, Maxar, Earthstar Geographics',
                }
              ),
            };

            layers.default.addTo(map);

            // Branded pin
            const icon = L.divIcon({
              className: 'kala-map-pin',
              html: '<span class="kala-pin-ring"></span><span class="kala-pin-dot"></span>',
              iconSize: [28, 28],
              iconAnchor: [14, 14],
            });
            L.marker(KALA_LATLNG, { icon, title: 'KALA · Greek and More' })
              .addTo(map)
              .bindPopup(
                '<strong>KALA &middot; Greek and More</strong><br/>1500 Queen Anne Ave N<br/>Seattle, WA 98109'
              );

            // Type toggle — scoped to the same .visit-map so multiple maps
            // on a page (future-proof) wouldn't clobber each other.
            const wrap = mount.closest('.visit-map') || document;
            const buttons = wrap.querySelectorAll('.map-type-btn');
            buttons.forEach((btn) => {
              btn.addEventListener('click', () => {
                const want = btn.dataset.mapType;
                Object.entries(layers).forEach(([key, layer]) => {
                  if (key === want) layer.addTo(map);
                  else map.removeLayer(layer);
                });
                buttons.forEach((b) =>
                  b.classList.toggle('is-active', b === btn)
                );
                // Tile sizes can stale after layer swap on some UAs.
                map.invalidateSize();
              });
            });

            // Tile rendering can break if Leaflet measures the container
            // before fonts / images / layout settle. Nudge it twice:
            // once on the next frame and once after a short delay.
            requestAnimationFrame(() => map.invalidateSize());
            setTimeout(() => map.invalidateSize(), 300);

            // Also revalidate when the viewport resizes or when the page
            // becomes visible again (back/forward cache).
            window.addEventListener('resize', () => map.invalidateSize());
            document.addEventListener('visibilitychange', () => {
              if (!document.hidden) map.invalidateSize();
            });
          };

          waitForLeaflet(0);
        })();
      </script>
    </div>
  </section>

  <!-- Additional info -->
  <section class="invite">
    <div class="container invite-inner">
      <span class="eyebrow">Beyond the dining room</span>
      <h2>Private events <em>&amp; press</em></h2>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus sit amet
        libero in lacus efficitur tincidunt.
      </p>
      <div class="invite-actions">
        <a href="mailto:niko@kalaeats.com" class="btn btn-primary btn-lg">
          Private Events
          <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11M11 5l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="mailto:niko@kalaeats.com" class="btn btn-outline btn-lg">Press Inquiries</a>
      </div>
    </div>
  </section>

</Base>
