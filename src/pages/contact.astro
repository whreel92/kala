---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact — KALA Greek and More"
  description="Visit, call, or write to KALA — Greek and More. Address, phone, email, hours, and directions."
  current="/contact"
>

  <!-- Page header -->
  <section class="page-header has-bg is-contact">
    <div class="container">
      <h1>CONTACT</h1>
      <span class="page-sub">Find us by the harbor</span>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed pretium nisi
        tincidunt eu. Donec euismod tempor lectus.
      </p>
    </div>
  </section>

  <!-- Greek Key Divider -->
  <div class="meander-divider" aria-hidden="true"></div>

  <!-- Contact details -->
  <section class="visit">
    <div class="container visit-grid">
      <div class="visit-info">
        <span class="eyebrow">The details</span>
        <h2 class="section-title">Stop by, call, <em>or write</em></h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec euismod
          tempor lectus, sed pretium nisi tincidunt eu.
        </p>

        <dl class="info-list">
          <div class="info-row">
            <dt>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 2c-3.3 0-6 2.6-6 6 0 4.4 6 10 6 10s6-5.6 6-10c0-3.4-2.7-6-6-6Zm0 8.2A2.2 2.2 0 1 1 10 5.8a2.2 2.2 0 0 1 0 4.4Z" fill="currentColor"/></svg>
              Address
            </dt>
            <dd>
              1500 Queen Anne Ave N<br/>
              Seattle, WA 98109
            </dd>
          </div>
          <div class="info-row">
            <dt>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 3h3l2 5-2 1a10 10 0 0 0 5 5l1-2 5 2v3a2 2 0 0 1-2 2A14 14 0 0 1 3 5a2 2 0 0 1 2-2Z" fill="currentColor"/></svg>
              Phone
            </dt>
            <dd><a href="tel:5551234567">(555) 123 — 4567</a></dd>
          </div>
          <div class="info-row">
            <dt>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5Zm2 .5v.4l5 3.4 5-3.4v-.4H5Zm10 2.1-5 3.4-5-3.4V14.5h10V7.6Z" fill="currentColor"/></svg>
              Email
            </dt>
            <dd><a href="mailto:niko@kalaeats.com">niko@kalaeats.com</a></dd>
          </div>
          <div class="info-row">
            <dt>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 2a8 8 0 1 0 0 16 8 8 0 0 0 0-16Zm.8 4h-1.6v5l4 2.4.8-1.4-3.2-2Z" fill="currentColor"/></svg>
              Hours
            </dt>
            <dd>
              <span><b>Tue – Thu</b> · 11a – 9p</span>
              <span><b>Fri – Sat</b> · 11a – 10p</span>
              <span><b>Sun</b> · 12p – 8p</span>
              <span class="dim"><b>Mon</b> · Closed</span>
            </dd>
          </div>
        </dl>

        <div class="visit-buttons">
          <a href="#" class="btn btn-primary">Get Directions</a>
          <a href="tel:5551234567" class="btn btn-outline">Call (555) 123-4567</a>
        </div>
      </div>

      <div class="visit-map" aria-hidden="true">
        <div class="map-frame">
          <div class="map-grid"></div>
          <div class="map-road map-road-h"></div>
          <div class="map-road map-road-v"></div>
          <div class="map-road map-road-d"></div>
          <div class="map-water">
            <div class="map-wave w1"></div>
            <div class="map-wave w2"></div>
            <div class="map-wave w3"></div>
          </div>
          <div class="map-pin">
            <span class="pin-ring"></span>
            <span class="pin-dot"></span>
          </div>
          <div class="map-label">1500 Queen Anne Ave N</div>
          <div class="map-legend">
            <span class="legend-dot"></span>KALA · Greek and More
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional info -->
  <section class="invite">
    <div class="container invite-inner">
      <span class="eyebrow">Beyond the dining room</span>
      <h2>Private events <em>&amp; press</em></h2>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus sit amet
        libero in lacus efficitur tincidunt.
      </p>
      <div class="invite-actions">
        <a href="mailto:niko@kalaeats.com" class="btn btn-primary btn-lg">
          Private Events
          <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10h11M11 5l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="mailto:niko@kalaeats.com" class="btn btn-outline btn-lg">Press Inquiries</a>
      </div>
    </div>
  </section>

</Base>
